{
  "name": "hoppspelet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:engine && pnpm run build:game",
    "build:engine": "tsc -p packages/minimotor --outDir public/minimotor",
    "build:game": "tsc",
    "dev": "tsc --watch",
    "dev:game": "tsc --watch",
    "dev:engine": "tsc -p packages/minimotor --outDir public/minimotor --watch",
    "dev:all": "pnpm -r --parallel --include-workspace-root run \"/^dev:(game|engine)$/\"",
    "lint": "oxlint",
    "format": "oxfmt .",
    "verify:tsc": "tsc --noEmit",
    "verify:lint": "oxlint",
    "verify:format": "oxfmt --check .",
    "verify": "pnpm -r --parallel --include-workspace-root run \"/^verify:.+$/\""
  },
  "dependencies": {
    "minimotor": "workspace:*"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.36.0",
    "typescript": "^5.9.0"
  }
}
