{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "browser": true
  },
  "rules": {
    "no-unused-vars": "error"
  },
  "ignorePatterns": ["public/", "packages/", "tools/"]
}
