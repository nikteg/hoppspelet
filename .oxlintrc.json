{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "browser": true
  },
  "rules": {
    // Game uses ES modules now; no-unused-vars is kept off to avoid noisy
    // warnings for internal helpers used only within their own file.
    "no-unused-vars": "off"
  },
  "ignorePatterns": ["public/", "packages/", "tools/"]
}
